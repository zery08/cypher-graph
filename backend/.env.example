# Neo4j 연결 설정
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# LLM 모델 설정 (OpenRouter 기본값)
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
COORDINATOR_MODEL=minimax/minimax-m2.5:free
CYPHER_MODEL=minimax/minimax-m2.5:free
ANSWER_MODEL=minimax/minimax-m2.5:free

# 쿼리 제한
MAX_QUERY_RESULTS=100

# Keycloak OIDC 설정
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=rcp
KEYCLOAK_CLIENT_ID=rcp-cypher
KEYCLOAK_CLIENT_SECRET=your_client_secret_here
KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/auth/callback
FRONTEND_URL=http://localhost:5173

# 세션 서명 키 (운영 환경에서 반드시 변경)
SESSION_SECRET=change-me-in-production

# PostgreSQL 설정
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rcp_cypher
